DATABASE_URL=sqlite+aiosqlite:///./recruiting_agent.db
DEBUG=False

# ===== GitHub =====
GITHUB_TOKEN=your_github_token_here

# ===== Email / SMTP =====
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_PORT=587
EMAIL_FROM=your_email@gmail.com

# ===== LLM 大模型配置 =====
# 支持所有 OpenAI 兼容接口（OpenAI / DeepSeek / 通义千问 / Ollama 等）
# 只需更换 LLM_API_BASE_URL 和 LLM_API_KEY 即可切换服务商

# OpenAI 官方
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-api-key-here
LLM_MODEL_NAME=gpt-4o

# DeepSeek
# LLM_API_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-your-deepseek-api-key
# LLM_MODEL_NAME=deepseek-chat

# 通义千问（DashScope OpenAI 兼容接口）
# LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-api-key
# LLM_MODEL_NAME=qwen-plus

# 本地部署（Ollama / vLLM 等）
# LLM_API_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=llama3

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60